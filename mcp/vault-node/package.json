{
  "name": "@codetrail/vault",
  "version": "0.1.0",
  "description": "Secret-by-reference MCP server (Node port of vault). LLM sees refs only; secret resolves from macOS keychain into subprocess env $SECRET.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "vault": "dist/server.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
